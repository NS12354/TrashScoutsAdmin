# ─── Database ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Public URL ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://trashscouts.example.com"
# NextAuth uses this to construct callback URLs in production.
NEXTAUTH_URL="https://trashscouts.example.com"

# ─── Auth (NextAuth + Google) ───────────────────────────────────────────
# 32+ random chars. Generate with: openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-string"
# Get these from Google Cloud → APIs & Services → Credentials → OAuth 2.0
# Authorized redirect URI must include: <YOUR_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Email (Resend) ─────────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="Trash Scouts <onboarding@resend.dev>"
NOTIFICATION_EMAIL="nayan@revisent.com"

# ─── Photo storage (Supabase Storage) ──────────────────────────────────
# Create a PUBLIC bucket (default name "uploads"). URL + service_role key
# are in Supabase → Project Settings → API. Leave empty in local dev to
# write to /public/uploads instead.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="uploads"

# ─── Brand ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_BRAND_NAME="Trash Scouts"
NEXT_PUBLIC_BRAND_LEGAL_NAME="Trash Scouts, LLC"
NEXT_PUBLIC_SUPPORT_EMAIL="support@trashscouts.example.com"
NEXT_PUBLIC_BRAND_LOGO="/brand/logo.jpg"
