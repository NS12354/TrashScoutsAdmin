// Trash Scouts platform schema. Postgres in prod (Neon free tier), same in
// local dev — Prisma's provider is fixed at this file, so use one DB engine.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Admins ──────────────────────────────────────────────────────────
model User {
  id             String    @id @default(cuid())
  email          String    @unique
  password       String // bcrypt hash; never the user's plaintext
  name           String
  createdAt      DateTime  @default(now())
  // Set when the user first chooses a password (via invite or reset). Null
  // means "invite pending" — they were added by another admin but haven't
  // completed setup yet. Password login refuses if this is null; Google SSO
  // bypasses it (and stamps it on first successful SSO sign-in).
  passwordSetAt  DateTime?
  // Google `sub` claim — stable identifier independent of email changes.
  // Stamped on first successful SSO; future SSO logins prefer it over email.
  googleSubject  String?   @unique

  resetTokens    PasswordResetToken[]
}

// Tokens for password setup (invite) + password reset (forgot). Same shape
// for both — the raw token is never stored, only its sha256 hash. Single-use:
// `usedAt` is set when consumed and the row is then ignored.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  purpose   String // "invite" | "reset"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ─── Porters (Trash Scout field staff) ──────────────────────────────
model Porter {
  id        String   @id @default(cuid())
  name      String
  title     String? // e.g. "Field Supervisor since 2020"
  photoUrl  String?
  // Optional contact email. When set, any issue reported at a property
  // this porter is assigned to is forwarded to this address (in addition
  // to the NOTIFICATION_EMAIL ops inbox).
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A porter can be assigned to many properties as the day-shift or
  // night-shift contact (or both for the same property).
  dayProperties   Property[] @relation("DayPorter")
  nightProperties Property[] @relation("NightPorter")
}

// ─── Properties (buildings) ─────────────────────────────────────────
model Property {
  id              String   @id @default(cuid())
  slug            String   @unique // url-safe identifier, e.g. "1919-market"
  name            String
  address         String
  latitude        Float?
  longitude       Float?
  // Which county the property is in — drives the county-specific recycling
  // agency link shown on the resident Recycling Guide. Values from
  // COUNTY_OPTIONS in lib/format.ts (e.g. "ALAMEDA"). Nullable: legacy
  // properties without a county still see the generic guide.
  county          String?
  // Direct link to the city/hauler's official sorting guide (PDF or web
  // page). Shown on the resident "What Goes Where" page so residents
  // get authoritative graphics from the agency rather than the generic
  // in-app text. Nullable: properties without a URL fall back to the
  // generic guide.
  guideUrl        String?
  hhwInstructions String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Two named porter slots — most properties have a morning person and an
  // evening person, so the resident "Meet your Trash Scouts" panel can show
  // both. Either slot is optional; the day slot is the legacy `porterId`
  // column so existing assignments don't break.
  porterId      String?
  porter        Porter? @relation("DayPorter", fields: [porterId], references: [id])
  nightPorterId String?
  nightPorter   Porter? @relation("NightPorter", fields: [nightPorterId], references: [id])

  setupPhotos  SetupPhoto[]
  schedule     ScheduleItem[]
  issues       Issue[]
  diversionReports DiversionReport[]
  proposals        Proposal[]
}

// ─── Setup photos (per property) ────────────────────────────────────
model SetupPhoto {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url        String
  // Two-line caption shown on the resident Setup Photos page. `caption`
  // is the heading (e.g. "Trash Room 1"); `subcaption` is the detail
  // line (e.g. "3 trash · 2 recycling · 1 organics"). Either may be
  // empty — legacy photos that used a single caption keep it in
  // `caption` and leave `subcaption` null.
  caption    String?
  subcaption String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
}

// ─── Service schedule rows (per property) ───────────────────────────
model ScheduleItem {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  dayOfWeek  Int // 0 = Sunday … 6 = Saturday
  binType    String // "TRASH" | "RECYCLING" | "ORGANICS" | "FIBER" | "BOTTLES_CANS" | "OTHER"
  action     String // "PULL_OUT" | "RETURN" | "SERVICE_DAY"
  binCount   Int?
  // Bin size in cubic yards (e.g. 0.158 for a 32-gallon cart, 2 for a 2 cu
  // yd dumpster). Drives the Diversion Report's automatic volume math —
  // without it, that property's report falls back to manual entry.
  binSize    Float?
  timeWindow String?
  notes      String?
  createdAt  DateTime @default(now())
}

// ─── Issue reports submitted by residents ───────────────────────────
model Issue {
  id              String   @id @default(cuid())
  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  category        String // see ISSUE_CATEGORIES in lib/format.ts
  description     String?
  reporterName    String?
  reporterContact String? // email
  reporterPhone   String? // optional phone number
  status          String   @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED
  photos          IssuePhoto[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model IssuePhoto {
  id      String @id @default(cuid())
  issueId String
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  url     String
}

// ─── Diversion reports (saved waste-diversion summaries) ────────────
// Each row is one generated report. Admins build a report in the
// /admin/diversion tool, save it, and can reopen it later. The waste-
// stream `rows` array is opaque to the DB (Json) — its shape lives in
// the builder component; storing it as JSON keeps the model flexible
// while we iterate.
model DiversionReport {
  id             String   @id @default(cuid())
  propertyId     String
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  // Display name of the admin who saved it. Stored as a string rather
  // than a User FK because we want it to survive admins being removed
  // and because it's display-only — no relational queries depend on it.
  createdByName  String?
  clientName     String
  address        String
  period         String
  propType       String
  mode           String // "volume" | "weight"
  rows           Json
  totalWeekly    Float
  divertedWeekly Float
  divRate        Float
  createdAt      DateTime @default(now())

  @@index([propertyId])
  @@index([createdAt])
}

// ─── Sent proposals + signed agreements ─────────────────────────────
// A Proposal is the snapshot an admin sends to a client. The token
// becomes the public URL (/proposals/<token>) — unguessable, no auth.
// All the data needed to render the proposal lives in `data` (the
// same SerializedTool envelope PricingQuote uses), so price + scope
// are preserved exactly as sent even if the underlying quote changes.
//
// SignedAgreement is the client's filled-and-signed copy. One proposal
// can have multiple signed agreements in theory (client signs, then
// resigns); the most recent one is the canonical record.
model Proposal {
  id             String   @id @default(cuid())
  token          String   @unique

  propertyId     String?
  property       Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  pricingQuoteId String?

  createdByName  String?
  clientName     String
  clientAddress  String?
  clientEmail    String
  preparedBy     String?

  data           Json
  monthlyPrice   Float
  weeklyPrice    Float
  breakEvenCost  Float
  validUntil     DateTime

  // Custom email body the admin sets at send time. `message` shows up
  // in the "proposal ready" email the client gets when the link is
  // sent. `thankYouMessage` shows up in the "signed copy" email after
  // the client signs. Both optional — fall back to the default
  // template copy when null.
  message         String?
  thankYouMessage String?

  // Point-of-contact emails to notify when the client signs. Stored
  // as a Postgres text[] so each proposal can have its own set of
  // recipients (account exec, ops lead, account manager, etc.) —
  // replacing the previous NOTIFICATION_EMAIL fallback for this
  // specific flow.
  pocEmails       String[] @default([])

  sentAt         DateTime?
  viewedAt       DateTime?
  acceptedAt     DateTime?

  createdAt      DateTime @default(now())

  agreements     SignedAgreement[]

  @@index([propertyId])
  @@index([createdAt])
}

model SignedAgreement {
  id             String   @id @default(cuid())
  proposalId     String
  proposal       Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  // All the form fields the client filled in (property info, contacts,
  // customer type, access notes). Opaque to the DB so the form shape
  // can evolve without migrations.
  formData       Json
  signatureType  String   // 'drawn' | 'typed'
  // Drawn: data URL of the canvas PNG. Typed: the text the client typed.
  // We use @db.Text since drawn-signature PNGs run 30–100 KB.
  signatureValue String   @db.Text
  // Only set when signatureType === 'typed' — captures which cursive
  // font the client picked so the signed copy renders identically.
  signatureFont  String?
  signerName     String
  signerTitle    String?

  signedAt       DateTime @default(now())

  @@index([proposalId])
}

// ─── Shared guides (waste + HHW) ────────────────────────────────────
// Two seeded rows: slug="waste" and slug="hhw". Resident pages render
// these via parseSections — see src/lib/parseSections.ts. Content is
// markdown-lite: "## Heading" + "- bullet".
model Guide {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String
  updatedAt DateTime @updatedAt
}
